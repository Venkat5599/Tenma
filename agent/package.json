{
  "name": "shieldpool-agent",
  "version": "1.0.0",
  "description": "Autonomous AI Agent for MEV-Protected Trading via ShieldPool",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/real-agent-api.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "agent:start": "ts-node src/agent.ts",
    "api:start": "ts-node src/api-server.ts",
    "api:dev": "nodemon --watch src --exec ts-node src/api-server.ts",
    "real-agent:start": "ts-node src/real-agent-api.ts",
    "real-agent:dev": "nodemon --watch src --exec ts-node src/real-agent-api.ts",
    "setup:database": "ts-node scripts/setup-database.ts",
    "strategy:dca": "ts-node src/strategies/dca.ts",
    "strategy:arbitrage": "ts-node src/strategies/arbitrage.ts",
    "postinstall": "npm run build"
  },
  "keywords": [
    "0g",
    "mev",
    "agent",
    "trading",
    "ai",
    "autonomous"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.0",
    "@langchain/openai": "^0.0.14",
    "@supabase/supabase-js": "^2.105.3",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "dotenv": "^16.4.1",
    "ethers": "^6.10.0",
    "express": "^4.18.2",
    "groq-sdk": "^0.7.0",
    "langchain": "^0.1.20",
    "openai": "^4.26.0",
    "redis": "^4.6.12",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
